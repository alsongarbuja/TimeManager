@page "/app/report"

@rendermode InteractiveServer

@inject HttpClient Http

@* @using TimeManager.Frontend.Components.Pages.Admin._Components *@
@using TimeManager.Frontend.Components.Shared
@using TimeManager.Frontend.Components.Wrapper

<PageTitle>Pay Period</PageTitle>

<ListWrapper Title="Report"
             Headers="@reportHeaders"
             Subtitle="Generate Reports for the pay period"
             hasCreate="false"
             isEmpty="isEmpty"
             hasAction="false">
    <DifferentActions>
        <CustomButton Type="button" HandleClick="HandleGenerateReport" Classes="btn-create">Generate Report</CustomButton>
    </DifferentActions>

    <ChildContent>
        @foreach (var data in reports)
        {
            var currentId = data.Id;
            <tr class="table-row">
                <td class="table-cell">@data.Name</td>
                <td class="table-cell">@data.TotalHours</td>
                <td class="table-cell">@data.TotalWorkedHours</td>
                <td class="table-cell">@data.TotalHolidayHours</td>
            </tr>
        }
    </ChildContent>
</ListWrapper>

@code {
    private string[] reportHeaders { get; set; } = ["Name", "Total Hours", "Worked Hours" , "Holiday Hours"];
    private ReportModel[] reports = [];
    private int jobProfileId = 8;

    private async Task HandleGenerateReport()
    {
        try
        {
            ReportModel data = await Http.GetFromJsonAsync<ReportModel>($"/api/report/{jobProfileId}");
            Console.WriteLine($"Total Hours = {data.TotalHours}");
            Console.WriteLine($"Total Worked Hours = {data.TotalWorkedHours}");
            Console.WriteLine($"Total Holiday Hours = {data.TotalHolidayHours}");
            Console.WriteLine($"Total Holiday Hours = {data.TotalHolidayHours}");

            foreach(string ok in data.WeekOne.Keys)
            {
                Console.Write(ok);
                Console.WriteLine($"{data.WeekOne[ok].Type} => {data.WeekOne[ok].Hours}");
            }

            foreach (string ok in data.WeekTwo.Keys)
            {
                Console.Write(ok);
                Console.WriteLine($"{data.WeekTwo[ok].Type} => {data.WeekTwo[ok].Hours}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex);
        }
    }

    private bool isEmpty => reports.Length == 0;
}
