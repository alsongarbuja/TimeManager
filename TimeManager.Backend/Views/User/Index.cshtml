@using TimeManager.Backend.Models.Components
@using TimeManager.Backend.ViewModels
@model IEnumerable<UserViewModel>

@{
    Layout = "_ListWrapper";
    ViewData["Title"] = "User";

    List<string> Headers = ["Name", "Email", ];
    ViewData["Headers"] = Headers;
    ViewData["ModuleTitle"] = "User";
    ViewData["ModuleDesc"] = "Manage the users in the system";
    ViewData["Controller"] = "User";
}

@if (Model.Count() <= 0)
{
    <tr>
        <td colspan="@Headers.Count"
            class="table-empty-cell">
            No data available
        </td>
    </tr>
}
else
{
    foreach (var d in Model)
    {
        <tr class="table-row">
            <td class="table-cell">@d.UserName</td>
            <td class="table-cell">@d.Email</td>
            @await Html.PartialAsync("ActionTd", new ActionTdViewModel
            {
                Controller = "User",
                Id = d.Id,
                hasEdit = true,
                hasDelete = true,
            })
        </tr>
    }
}