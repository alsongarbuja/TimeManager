            } else
            {
                <div class="scanner-zone">
                    <div class="card-silhouette">
                        <div class="barcode-lines"></div>
                        <div class="laser-line"></div>
                    </div>
                </div>
            }

            <h1 class="title">Scan ID Card</h1>

            <EditForm Model="@cioModel" FormName="ClockInOutForm" OnValidSubmit="HandleClockInOut">
                <input @ref="myIdeo" class="textfield-minimal" autofocus type="text"
                       name="UniqueId" @bind-value="cioModel.UniqueId"
                   placeholder="@(isSubmitting ? "Processing punch..." : "Waiting for scan...")"
                   autocomplete="off"
                   disabled="@isSubmitting"            />
            </EditForm>

            <p class="helper-text">or type your ID and press <kbd>Enter</kbd></p>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert-error">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                        <path d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0zM7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 4.995z"/>
                    </svg>
                    <span>@errorMessage</span>
                </div>
            }
        </div>
    </div>

    @if (showModal)
    {
        <div class="success-modal-overlay">
            <div class="success-modal @modalBg">
                <div class="modal-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
                    </svg>
                </div>
                <h2 class="modal-title">@apiMessage</h2>
                <p class="modal-time">@operationTime</p>
                <p class="modal-greeting">@greetingMessage</p>
                <div class="modal-progress-bar"></div>
            </div>
        </div>
    }
@* } *@

@code {
    private ElementReference myIdeo;
    private string errorMessage = "";

    private bool isInitializing = true;
    private bool initFailed = false;
    private bool isAvailable = true;
    private bool isSubmitting = false;

    private bool showModal = false;
    private string apiMessage = "";
    private string operationTime = "";
    private string greetingMessage = "";
    private string modalBg = "";

    private class ClockInOutModel
    {
        public string UniqueId { get; set; } = "";
    }
    private ClockInOutModel cioModel = new();

    public record ApiErrorResponse(string Message, bool IsClockedOut, string Status, string Time, string Greeting);

    // protected override async Task OnInitializedAsync()
    // {
    //     await InitializeKiosk();
    // }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // if (!isInitializing && !initFailed)
        if (!isSubmitting)
        {        
            await myIdeo.FocusAsync();
        }
    }

    // private async Task InitializeKiosk()
    // {
    //     isInitializing = true;
    //     initFailed = false;

    //     var success = await KioskSession.InitializedAsync();

    //     isInitializing = false;
    //     initFailed = !success;

    //     StateHasChanged();
    // }

    private async Task HandleClockInOut()
    {
        if (!isAvailable || isSubmitting || string.IsNullOrEmpty(cioModel.UniqueId))
        {
            return;
        }

        try
        {
            isSubmitting = true;
            errorMessage = "";
            StateHasChanged();

            // if (!KioskSession.IsInitialized)
            // {
            //     await InitializeKiosk();
            //     if (initFailed) return;
            // }

            var res = await Http.PostAsJsonAsync("api/punch", new
            {
                UniqueId = cioModel.UniqueId,
                DepartmentId = 1,
            });

            // if (res.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            // {
            //     KioskSession.Invalidate();
            //     await InitializeKiosk();
            //     if (initFailed) return;

            //     res = await Http.PostAsJsonAsync("api/punch", new { UniqueId = cioModel.UniqueId });
            // }

            var result = await res.Content.ReadFromJsonAsync<ApiErrorResponse>();
            if (result is not null)
            {
                if (!res.IsSuccessStatusCode)
                {
                    errorMessage = result.Message;
                }
                else
                {
                    modalBg = result.IsClockedOut ? "success-modal-out" : "success-modal-in";
                    apiMessage = result.Message ?? "Operation Successful";
                    operationTime = result.Time ?? DateTime.Now.ToString("hh:mm tt");
                    greetingMessage = result.Greeting ?? "Have a great day!";

                    await TriggerSuccessModal();
                }
            }

            cioModel.UniqueId = "";
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex);
            errorMessage = "An unexpected error occurred. Please try again.";
        } finally
        {
            isSubmitting = false;
            StateHasChanged();
        }
    }

    private async Task TriggerSuccessModal()
    {
        showModal = true;
        isAvailable = false;
        StateHasChanged();

        await Task.Delay(2500);

        showModal = false;
        isAvailable = true;
        StateHasChanged();

        await myIdeo.FocusAsync();
    }
}