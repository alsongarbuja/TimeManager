@model TimeManager.Backend.ViewModels.ReportGeneratedUnitViewModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Unit Report";

    var days = new[] { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday" };
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
    .rg-spin {
        display: inline-block;
        animation: rg-spin-anim 0.8s linear infinite;
    }

    @@keyframes rg-spin-anim {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    .rg-back--loading,
    .rg-back:disabled {
        opacity: 0.7;
        cursor: not-allowed;
        pointer-events: none;
    }
</style>

<div class="report-page-page">

    <div class="report-page-header">
        <div class="report-page-header-text">
            @if (Model.Reports.Count > 0)
            {
                <p class="report-page-subtitle">@Model.Reports[0]?.UnitName (@Model.Reports[0]?.UnitIndex) Overview</p>
            }
            <h1 class="report-page-title">Reports by Unit</h1>
        </div>
        <form asp-controller="Report" asp-action="ExportToExcel" method="post" id="exportForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="UnitId" value="@Model.UnitId" />
            <input type="hidden" name="PayPeriodId" value="@Model.PayPeriodId" />
            <Button type="submit" class="report-page-back" id="exportBtn">
                <i class="ri-download-line" id="exportBtnIcon"></i> <span id="exportBtnLabel">Download Excel</span>
            </Button>
        </form>
        <a asp-controller="Report" asp-action="Index" class="report-page-back">← Back to Reports</a>
    </div>

    @if (Model.Reports.Any())
    {
        <!-- User jump selector -->
        <div class="rbu-controls">
            <div class="rbu-select-wrap">
                <label class="rbu-select-label" for="userJump">Jump to user</label>
                <div class="rbu-select-outer">
                    <select id="userJump" class="rbu-select" onchange="jumpToUser(this.value)">
                        <option value="">— Select a user —</option>
                        @foreach (var report in Model.Reports)
                        {
                            <option value="user-@report.JobProfileId">@report.Name</option>
                        }
                    </select>
                    <span class="rbu-select-chevron">▾</span>
                </div>
            </div>

            <button class="rbu-expand-all" type="button" onclick="toggleAll(this)">Expand all</button>
        </div>

        <div class="rbu-accordion" id="accordionRoot">
            @foreach (var report in Model.Reports)
            {
                <div class="rbu-item" id="user-@report.JobProfileId">

                    <button class="rbu-trigger" type="button" onclick="toggleItem(this)" aria-expanded="false">
                        <div class="rbu-trigger-left">
                            <span></span>
                            <span class="rbu-trigger-name">@report.Name</span>
                        </div>
                        <div class="rbu-trigger-right">
                            <span class="rbu-pill">@report.TotalHours.ToString("F2") hrs</span>
                            <span class="rbu-chevron">›</span>
                        </div>
                    </button>

                    <div class="rbu-body">
                        <div class="rbu-body-inner">

                            @await Html.PartialAsync("ReportStat", new TimeManager.Backend.ViewModels.PartialViews.ReportStatModel
                            {
                                TotalHours = report.TotalHours,
                                TotalWorkedHours = report.TotalWorkedHours,
                                TotalHolidayHours = report.TotalHolidayHours,
                            })

                            @await Html.PartialAsync("ReportTable", new TimeManager.Backend.ViewModels.PartialViews.ReportTablePartialViewModel
                            {
                                TotalHours = @report.TotalHours,
                                WeekOne = new TimeManager.Backend.ViewModels.PartialViews.ReportTableWeekRow
                                {
                                    Week = report.WeekOne,
                                    Label = "Week 1"
                                },
                                WeekTwo = new TimeManager.Backend.ViewModels.PartialViews.ReportTableWeekRow
                                {
                                    Week = report.WeekTwo,
                                    Label = "Week 2"
                                },
                            })

                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="rbu-empty">
            <p class="rbu-empty-text">No reports found for this unit.</p>
        </div>
    }

</div>

@section scripts {
    <script src="~/js/report.js" defer></script>
}