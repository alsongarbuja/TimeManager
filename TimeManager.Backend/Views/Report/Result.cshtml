@model TimeManager.Backend.ViewModels.ReportGeneratedViewModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Report Result";

    var days = new[] { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday" };
}

<div class="page-container">
    <div class="page-content-wrapper">

        <div class="page-header">
            <div>
                <h1 class="page-title">Report — @Model.Name</h1>
                <p class="page-subtitle">Job Profile #@Model.JobProfileId</p>
            </div>
            <a asp-controller="Report" asp-action="Index" class="btn-back">← Back</a>
        </div>

        <div class="report-summary">
            <div class="stat-card">
                <span class="stat-label">Total Hours</span>
                <span class="stat-value">@Model.TotalHours.ToString("F2")</span>
            </div>
            <div class="stat-card">
                <span class="stat-label">Worked Hours</span>
                <span class="stat-value">@Model.TotalWorkedHours.ToString("F2")</span>
            </div>
            <div class="stat-card">
                <span class="stat-label">Holiday Hours</span>
                <span class="stat-value">@Model.TotalHolidayHours.ToString("F2")</span>
            </div>
        </div>

        <div class="card mt-4">
            <table class="table">
                <thead>
                    <tr>
                        <th>Week</th>
                        @foreach (var day in days)
                        {
                            <th>@day</th>
                        }
                        <th>Total</th>
                    </tr>
                </thead>
                <tbody>
                    @await Html.PartialAsync("_WeekRow", (Model.WeekOne, "Week 1", days))
                    @await Html.PartialAsync("_WeekRow", (Model.WeekTwo, "Week 2", days))
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="@(days.Length + 1)"></td>
                        <td class="total-cell">@Model.TotalHours.ToString("F2")</td>
                    </tr>
                </tfoot>
            </table>
        </div>

    </div>
</div>