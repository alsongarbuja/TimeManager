@inject NavigationManager Navigation

@using TimeManager.Frontend.Components.Shared

<td class="table-actions">
    @ChildContent
    
    @if(hasDelete)
    {
        <Button Type="button" Classes="btn-action-delete" >
            <i class="ri-delete-bin-7-line"></i>
        </Button>
    }

    @if(hasEdit)
    {
        <a href="@Url" class="btn btn-action-edit">
            <i class="ri-edit-line"></i>
        </a>
    }
</td>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public bool hasDelete { get; set; } = true;
    [Parameter] public bool hasEdit { get; set; } = true;
    [Parameter] public required string Url { get; set; }
}
