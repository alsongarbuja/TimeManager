@page
@model TimeManager.Backend.Pages.App.EmployeeType.IndexModel
@{
    Layout = "_ListWrapper";
    ViewData["Title"] = "Employee Type";

    List<string> Headers = ["Name", "Description"];
    ViewData["Headers"] = Headers;
    ViewData["ModuleTitle"] = "Employee Type";
    ViewData["ModuleDesc"] = "Manage the employee types in the system";
    ViewData["CreateUrl"] = "employeetype/add";
}

@if (Model.EmployeeTypes.Count() <= 0)
{
    <tr>
        <td colspan="@Headers.Count"
            class="table-empty-cell">
            No data available
        </td>
    </tr>
}
else
{
    foreach (var d in Model.EmployeeTypes)
    {
        <tr class="table-row">
            <td class="table-cell">@d.Name</td>
            <td class="table-cell table-desc">@d.Description</td>
        </tr>
    }
}