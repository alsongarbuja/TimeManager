@page "/app/pay-period"

@inject HttpClient Http

@using TimeManager.Frontend.Components.Pages.Admin._Components
@using TimeManager.Frontend.Components.Shared
@using TimeManager.Frontend.Components.Wrapper

<PageTitle>Pay Period</PageTitle>

<ListWrapper Title="Pay Period"
             Headers="@payPeriodHeaders"
             Subtitle="Manage the Pay Periods"
             hasCreate="false"
             isEmpty="isEmpty"
             hasAction="false"
>
    <DifferentActions>
        @* TODO: Add some reload to fetch the pay periods *@
        <EditForm Model="@numOfPeriods" FormName="PayPeriodAutoGenerateForm" OnValidSubmit="HandleGeneratePayPeriod">
            @* <AntiforgeryToken /> *@
            <input type="hidden" value="26" name="numOfPeriods" />
            <Button Type="submit" Classes="btn-create">Generate Pay Period</Button>
        </EditForm>
    </DifferentActions>

    <ChildContent>
        @foreach (var data in payPeriods)
        {
            var currentId = data.Id;
            <tr class="table-row">
                <td class="table-cell">@data.StartDate.ToHumanReadable()</td>
                <td class="table-cell table-cell-desc">@data.EndDate.ToHumanReadable()</td>
                <ActionTD Url="@($"/app/department/edit/{data.Id}")" />
            </tr>
        }
    </ChildContent>
</ListWrapper>

@code {
    private string[] payPeriodHeaders { get; set; } = ["Start Date", "End Date"];
    private PayPeriodModel[] payPeriods = [];
    private int numOfPeriods = 26;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            payPeriods = await Http.GetFromJsonAsync<PayPeriodModel[]>("api/payperiod");
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex);
        }
    }

    private async Task HandleGeneratePayPeriod()
    {
        try
        {
            await Http.PostAsJsonAsync("/api/payperiod/auto-generate", new
            {
                numOfPeriods
            });
        } catch(Exception ex)
        {
            Console.WriteLine(ex);
        }
    }

    private bool isEmpty => payPeriods.Length == 0;
}
