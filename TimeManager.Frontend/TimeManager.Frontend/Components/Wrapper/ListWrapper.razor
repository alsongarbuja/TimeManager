<div class="page-container">
    <div class="page-content-wrapper">

        <div class="page-header">
            <div>
                <h1 class="page-title">
                    @Title
                </h1>

                <p class="page-subtitle">
                    @Subtitle
                </p>
            </div>

            <a href="@CreateUrl"
               class="btn-create">
                Create
            </a>
        </div>

        <div class="table-card">
            <div class="table-responsive">
                <table class="data-table">

                    <thead class="table-header">
                        <tr>
                            @foreach (var header in Headers)
                            {
                                <th class="table-header-cell">
                                    @header
                                </th>
                            }
                            @if (hasAction)
                            {
                                <th class="table-header-cell">
                                    Action
                                </th>
                            }
                        </tr>
                    </thead>

                    <tbody class="table-body">
                        @if (isEmpty)
                        {
                            <tr>
                                <td colspan="@Headers.Length"
                                    class="table-empty-cell">
                                    No data available
                                </td>
                            </tr>
                        } else
                        {
                            @ChildContent
                        }
                    </tbody>

                </table>
            </div>
        </div>

    </div>
</div>

@code {
    [Parameter] public required string Title { get; set; }

    [Parameter]
    public string Subtitle { get; set; }
        = "Manage and review your data.";

    [Parameter] public required string[] Headers { get; set; }

    [Parameter] public string CreateUrl { get; set; } = "#";

    [Parameter] public bool isEmpty { get; set; } = false;

    [Parameter] public bool hasAction { get; set; } = true;

    [Parameter] public RenderFragment? ChildContent { get; set; }
}