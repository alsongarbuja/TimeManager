@model TimeManager.Backend.ViewModels.UnitViewModel

@{
    Layout = "_FormWrapper";
    ViewData["Title"] = "Unit - Edit";
    ViewData["ModuleTitle"] = "Edit Unit";
    ViewData["ModuleSubtitle"] = "Update unit data";
    ViewData["Controller"] = "Unit";
}

<form asp-controller="Unit" asp-action="Edit" method="post" asp-route-id="@Model.Id">
    @Html.AntiForgeryToken()
    
    <custom-input asp-for="Name" />
    <custom-input asp-for="Index" />
    <custom-input asp-for="Description" />
    @if (User.IsInRole("SuperAdmin"))
    {
        <custom-select asp-for="DepartmentId" asp-items="@Model.Departments" />
    }

    <button type="submit" class="btn btn-primary">Submit</button>
</form>