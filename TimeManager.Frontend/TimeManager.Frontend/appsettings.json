{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "api": {
        "ClusterId": "apiCluster",
        "Match": { "Path": "/api/{**catch-all}" },
        "Transforms": [
          { "RequestHeadersCopy": "true" },
          { "ResponseHeadersCopy": "true" }
        ]
      }
    },
    "Clusters": {
      "apiCluster": {
        "Destinations": {
          "dest1": { "Address": "https://localhost:7263" }
        }
      }
    }
  }
}
