@page "/app/department/edit/{id:int}"

@rendermode InteractiveServer
@inject HttpClient Http

@using TimeManager.Frontend.Components.Shared
@using TimeManager.Frontend.Components.Wrapper

<PageTitle>Edit Department</PageTitle>

<FormWrapper 
    isEdit="true"
    Title="Department"
    Subtitle="Update the department data"
    BackUrl="/app/department"
    Model="@departmentModel"
    FormName="DepartmentEditForm" 
    OnSubmit="HandleSubmit"
    OnCancel="Cancel"
>
    <Input @bind-Value="departmentModel.Name" Label="Name" Name="Name" Placeholder="Enter a name" /> 
    <Input @bind-Value="departmentModel.Description" Label="Description" Name="Description" Placeholder="Enter a descrption" Required="false" />
</FormWrapper>

@code {
    [Parameter]
    public int Id { get; set; }

    private bool _hasDataLoaded = false;
    private DepartmentModel departmentModel = new ();

   
    protected override async Task OnParametersSetAsync()
    {
        if (_hasDataLoaded) return;
        try
        {
            var data = await Http.GetFromJsonAsync<DepartmentModel>($"api/department/{Id}");

            if (data != null)
            {
                Console.WriteLine("The data is loaded");
                departmentModel.Name = data.Name;
                departmentModel.Description= data.Description;
                _hasDataLoaded = true;
            }
        } catch (Exception ex)
        {
            Console.WriteLine(ex);
        }
    }

    private async Task<string> HandleSubmit()
    {
        Console.WriteLine(departmentModel.Description);
        try
        {
            HttpResponseMessage res = await Http.PatchAsJsonAsync($"api/department/{Id}", departmentModel);

            if (res.IsSuccessStatusCode)
            {
                return "";
            }
            else
            {
                var problemDetails = await res.Content.ReadFromJsonAsync<System.Text.Json.Nodes.JsonObject>();
                Console.WriteLine(problemDetails);
                return problemDetails?["detail"]?.ToString() ?? "An error occured while saving.";
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex);
            return ex.Message;
        }
    }

    private Task Cancel()
    {
        Console.WriteLine("Cancelling...");
        return Task.CompletedTask;
    }
}
