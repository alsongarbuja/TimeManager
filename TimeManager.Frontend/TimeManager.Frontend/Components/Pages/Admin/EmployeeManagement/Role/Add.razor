@page "/app/role/create"

@rendermode InteractiveServer
@inject HttpClient Http

@using TimeManager.Frontend.Components.Shared
@using TimeManager.Frontend.Components.Wrapper

<PageTitle>Role - Add</PageTitle>

<FormWrapper Title="Role"
             Subtitle="Add role to the system"
             BackUrl="/app/role"
             FormName="RoleAddForm"
             Model="@role"
             OnSubmit="HandleSubmit"
             OnCancel="Cancel"
             >
    <Input @bind-Value="role.Name" Name="Name" Label="Name" Placeholder="Give the device a name" />
    <Input @bind-Value="role.Description" Required="false" Name="Description" Label="Description" Placeholder="Give it a descriptive info" />
</FormWrapper>

@code {
    private RoleModel role = new();

    private async Task<string> HandleSubmit()
    {
        try
        {
            HttpResponseMessage responseMessage = await Http.PostAsJsonAsync("api/role", role);

            if (responseMessage.IsSuccessStatusCode)
            {
                return "";
            }
            else
            {
                var problemDetails = await responseMessage.Content.ReadFromJsonAsync<System.Text.Json.Nodes.JsonObject>();
                return problemDetails?["detail"]?.ToString() ?? "An unexpected error occured";
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex);
            return ex.Message;
        }
    }

    private Task Cancel()
    {
        return Task.CompletedTask;
    }
}
