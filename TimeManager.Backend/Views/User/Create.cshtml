@model TimeManager.Backend.ViewModels.RegisterViewModel

@{
    Layout = "_FormWrapper";
    ViewData["Title"] = "User - Add";
    ViewData["ModuleTitle"] = "Create User";
    ViewData["ModuleSubtitle"] = "Add new user";
    ViewData["Controller"] = "User";
}

@section scripts {
    <script src="~/js/passwordtoggle.js" defer></script>
}

<form asp-controller="User" asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    <custom-input asp-for="Email" />
    <custom-select asp-for="Role" asp-items="@Model.AvailableRoles" />
    <custom-input asp-for="Password" />
    <custom-input asp-for="ConfirmPassword" />

    <button type="submit" class="btn btn-primary">Submit</button>
</form>