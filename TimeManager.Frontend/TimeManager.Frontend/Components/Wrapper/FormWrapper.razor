@using TimeManager.Frontend.Components.Shared

<div class="min-h-screen">
    <div class="mx-auto">

        <div class="mb-8 flex items-start justify-content-center gap-4">
            <a href="@BackUrl"
               class="inline-flex items-center rounded-xl border border-gray-300 bg-white px-5 py-2.5 text-sm font-medium text-black transition-all duration-200 hover:bg-gray-50">
                ← Back
            </a>

            <div>
                <h1 class="text-3xl font-bold tracking-tight text-black">
                    @if (!isEdit)
                    {
                        @("Create ")
                    } else {
                        @("Edit ")
                    }
                    @Title
                </h1>

                <p class="mt-2 text-sm text-gray-500">
                    @Subtitle
                </p>
            </div>

            

        </div>

        <div class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm">

            <EditForm Model="@Model" OnValidSubmit="Submit" FormName="@FormName">
                <DataAnnotationsValidator />
                <ValidationSummary />

                @if (!String.IsNullOrEmpty(message))
                {
                    <span class="text-green-500 mb-4">@message</span>
                }
                @if (!String.IsNullOrEmpty(errorMessage))
                {
                    <span class="text-red-500 mb-4">@errorMessage</span>
                }

                <div class="space-y-6">
                    @ChildContent
                </div>

                <div class="mt-8 flex justify-end gap-3 border-t border-gray-100 pt-6">

                    <Button 
                        Type="button"
                        HandleClick="OnCancel"
                            Classes="rounded-xl border border-gray-300 px-5 py-2.5 text-sm font-medium text-black hover:bg-gray-50">
                            Cancel</Button>

                    <Button 
                        Type="submit"
                        Classes="rounded-xl bg-black px-5 py-2.5 text-sm font-medium text-white hover:bg-gray-800"
                        Loading="@isLoading"
                        Disabled="@isLoading"
                        >Save</Button>
                </div>

            </EditForm>

        </div>

    </div>
</div>

@code {
    private string message = "";
    private string errorMessage = "";
    private bool isLoading = false;

    [Parameter] public required string Title { get; set; }
    [Parameter] public required bool isEdit { get; set; } = false;

    [Parameter]
    public string Subtitle { get; set; }
        = "Fill in the details below.";

    [Parameter] public string BackUrl { get; set; } = "/";

    [Parameter] public object? Model { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter] public Func<Task<string>>? OnSubmit { get; set; }

    [Parameter] public EventCallback OnCancel { get; set; }

    [Parameter] public string? FormName { get; set; }


    private async Task Submit()
    {
        isLoading = true;
        message = "";
        errorMessage = "";

        try
        {  
            if (OnSubmit != null)
            {
                string err = await OnSubmit.Invoke();

                if (string.IsNullOrEmpty(err))
                {
                    message = $"Succefully submitted {Title}";
                } else {
                    errorMessage = err;
                }
            }
        } finally
        {
            isLoading = false;
        }
    }
}