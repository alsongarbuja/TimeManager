@page "/app/pay-frequency/edit/{id:int}"

@rendermode InteractiveServer
@inject HttpClient Http

@using TimeManager.Frontend.Components.Shared
@using TimeManager.Frontend.Components.Wrapper

<PageTitle>Edit Pay Frequency</PageTitle>

<FormWrapper isEdit
             Title="Pay Frequency"
             Subtitle="Update the pay frequency"
             BackUrl="/app/pay-frequency"
             Model="@payFrequencyModel"
             OnSubmit="HandleSubmit"
             OnCancel="Cancel">
    <Input @bind-Value="payFrequencyModel.Name" Label="Name" Name="name" Placeholder="Enter a name" />
    <Input @bind-Value="payFrequencyModel.Description" Label="Description" Name="description" Placeholder="Enter a descrption" Required="false" />
</FormWrapper>

@code {
    [Parameter]
    public int Id { get; set; }

    private bool _hasDataLoaded = false;
    private PayFrequencyModel payFrequencyModel = new();

    protected override async Task OnParametersSetAsync()
    {
        if (!_hasDataLoaded)
        {
            try
            {
                var data = await Http.GetFromJsonAsync<PayFrequencyModel>($"/api/payFrequency/{Id}");

                if (data != null)
                {
                    payFrequencyModel = data;
                    _hasDataLoaded = true;
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine(ex);
            }
        }
    }

    private async Task<string> HandleSubmit()
    {
        try
        {
            HttpResponseMessage responseMessage = await Http.PatchAsJsonAsync($"/api/payFrequency/{Id}", payFrequencyModel);

            if (responseMessage.IsSuccessStatusCode)
            {
                return "";
            }
            else
            {
                var problemDetails = await responseMessage.Content.ReadFromJsonAsync<System.Text.Json.Nodes.JsonObject>();
                return problemDetails?["detail"]?.ToString() ?? "An error occured while saving.";
            }
        }
        catch (Exception ex)
        {
            return ex.Message;
        }
    }

    private Task Cancel()
    {
        Console.WriteLine("Cancelling...");
        return Task.CompletedTask;
    }
}
