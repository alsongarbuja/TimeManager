@model TimeManager.Backend.ViewModels.SelectProfileViewModel

@{
    Layout = "_MainLayout";
    ViewData["Title"] = "Select Profile";
}

@section scripts {
    <script defer>
        document.querySelectorAll('.profile-option input[type="radio"]').forEach(radio => {
            radio.addEventListener('change', () => {
                console.log('hello');
                document.getElementById('continueBtn').disabled = false;
            });
        });
    </script>
}

<style>
    .profile-list {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .profile-option {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem;
        border: 1.5px solid #e5e7eb;
        border-radius: 0.5rem;
        cursor: pointer;
        transition: border-color 150ms, background-color 150ms;
        background-color: #ffffff;
    }

    .profile-option:hover {
        border-color: #9ca3af;
        background-color: #f9fafb;
    }

    .profile-option:has(input:checked) {
        border-color: #111827;
        background-color: #f9fafb;
    }

    .profile-option input[type="radio"] {
        appearance: none;
        position: absolute;
        width: 0;
        height: 0;
        opacity: 0;
    }

    .radio-indicator {
        width: 18px;
        height: 18px;
        border-radius: 50%;
        border: 2px solid #d1d5db;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: border-color 150ms;
    }

    .profile-option:has(input:checked) .radio-indicator {
        border-color: #111827;
    }

    .radio-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background-color: #111827;
        opacity: 0;
        transition: opacity 150ms;
    }

    .profile-option:has(input:checked) .radio-dot {
        opacity: 1;
    }

    .profile-info {
        flex: 1;
    }

    .profile-title {
        font-size: 0.9375rem;
        font-weight: 600;
        color: #111827;
    }

    .profile-dept {
        font-size: 0.8125rem;
        color: #6b7280;
        margin-top: 2px;
    }

    .profile-hint {
        font-size: 0.8125rem;
        color: #9ca3af;
        text-align: center;
        margin-top: 1rem;
    }

    .container {
        height: 100dvh;
        width: 100vw;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }
</style>

<div class="container">
    <div class="wrapper">
        <h2 class="wrapper-title text-center">Select a profile</h2>
        <p class="wrapper-subtitle text-center">
            You have multiple profiles. Choose one to continue.
        </p>
    </div>

    <div class="mt-8 form-wrapper">
        <div class="form-card">
            <form asp-controller="Auth" asp-action="SelectProfile" method="post" class="space-y-6">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="error-alert" role="alert"></div>

                <div class="profile-list">
                    @foreach (var profile in Model.Profiles)
                    {
                        <label class="profile-option" for="profile_@profile.Id">
                            <input type="radio"
                                   id="profile_@profile.Id"
                                   name="SelectedProfileId"
                                   value="@profile.Id"
                                   required />
                            <div class="radio-indicator">
                                <div class="radio-dot"></div>
                            </div>
                            <div class="profile-info">
                                <div class="profile-title">@profile.Title</div>
                                <div class="profile-dept">@profile.DepartmentName</div>
                            </div>
                        </label>
                    }
                </div>

                @await Html.PartialAsync("Button", new TimeManager.Backend.ViewModels.PartialViews.ButtonViewModel
                {
                    Id = "continueBtn",
                    Classes = "w-100",
                    Type = "submit",
                    Text = "Select & Continue to dashboard"
                })

                
                <p class="profile-hint">
                    You can switch profiles later from your account settings.
                </p>
            </form>
        </div>
    </div>
</div>