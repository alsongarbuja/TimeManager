@page "/app/employee/edit/{id:int}"

@rendermode InteractiveServer
@inject HttpClient Http

@using TimeManager.Frontend.Components.Shared
@using TimeManager.Frontend.Components.Wrapper

<PageTitle>Edit Employee</PageTitle>

<FormWrapper isEdit
             Title="Employee"
             Subtitle="Update the employee"
             BackUrl="/app/employee"
             Model="@employeeModel"
             OnSubmit="HandleSubmit"
             OnCancel="Cancel">
    <Input @bind-Value="employeeModel.FirstName" Name="FirstName" Label="First Name" Placeholder="Enter the first name" />
    <Input @bind-Value="employeeModel.LastName" Name="LastName" Label="Last Name" Placeholder="Enter the last name" />
    <Input @bind-Value="employeeModel.Email" Type="email" Name="Email" Label="Email" Placeholder="Enter the email address" />
    <Input @bind-Value="employeeModel.UniqueId" Name="UniqueId" Label="SO Id" Placeholder="Enter the SO Id" />
</FormWrapper>

@code {
    [Parameter]
    public int Id { get; set; }

    private bool _hasDataLoaded = false;
    private EmployeeModel employeeModel = new();

    protected override async Task OnParametersSetAsync()
    {
        if (!_hasDataLoaded)
        {
            try
            {
                var data = await Http.GetFromJsonAsync<EmployeeModel>($"/api/employee/{Id}");

                if (data != null)
                {
                    employeeModel = data;
                    _hasDataLoaded = true;
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine(ex);
            }
        }
    }

    private async Task<string> HandleSubmit()
    {
        try
        {
            HttpResponseMessage responseMessage = await Http.PatchAsJsonAsync($"/api/employee/{Id}", employeeModel);

            if (responseMessage.IsSuccessStatusCode)
            {
                return "";
            }
            else
            {
                var problemDetails = await responseMessage.Content.ReadFromJsonAsync<System.Text.Json.Nodes.JsonObject>();
                return problemDetails?["detail"]?.ToString() ?? "An error occured while saving.";
            }
        }
        catch (Exception ex)
        {
            return ex.Message;
        }
    }

    private Task Cancel()
    {
        Console.WriteLine("Cancelling...");
        return Task.CompletedTask;
    }
}
