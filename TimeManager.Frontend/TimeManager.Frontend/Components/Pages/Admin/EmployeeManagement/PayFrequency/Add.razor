@page "/app/pay-frequency/create"

@rendermode InteractiveServer
@inject HttpClient Http

@using TimeManager.Frontend.Components.Shared
@using TimeManager.Frontend.Components.Wrapper

<PageTitle>Pay Frequency - Add</PageTitle>

<FormWrapper Title="Pay Frequency"
             Subtitle="Add pay frequency to the system"
             BackUrl="/app/pay-frequency"
             FormName="PayFrequencyAddForm"
             Model="@payFrequency"
             OnSubmit="HandleSubmit"
             OnCancel="Cancel"
             >
    <Input @bind-Value="payFrequency.Name" Name="Name" Label="Name" Placeholder="Give the device a name" />
    <Input @bind-Value="payFrequency.Description" Required="false" Name="Description" Label="Description" Placeholder="Give it a descriptive info" />
</FormWrapper>

@code {
    private PayFrequencyModel payFrequency = new();

    private async Task<string> HandleSubmit()
    {
        try
        {
            HttpResponseMessage responseMessage = await Http.PostAsJsonAsync("api/payfrequency", payFrequency);

            if (responseMessage.IsSuccessStatusCode)
            {
                return "";
            }
            else
            {
                var problemDetails = await responseMessage.Content.ReadFromJsonAsync<System.Text.Json.Nodes.JsonObject>();
                return problemDetails?["detail"]?.ToString() ?? "An unexpected error occured";
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex);
            return ex.Message;
        }
    }

    private Task Cancel()
    {
        return Task.CompletedTask;
    }
}
