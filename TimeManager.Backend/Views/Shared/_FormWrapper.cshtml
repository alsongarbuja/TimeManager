@{
    Layout = "_AdminLayout";
    var backUrl = ViewData["BackUrl"] as string;
    var title = ViewData["ModuleTitle"] as string;
    var subtitle = ViewData["ModuleSubtitle"] as string;
}

<div class="page-container">
    <div class="page-content-wrapper">

        <div class="page-header">
            <a asp-action"="Index"
               class="btn-back">
                ← Back
            </a>

            <div>
                <h1 class="page-title">
                    @title
                </h1>

                <p class="page-subtitle">
                    @subtitle
                </p>
            </div>

        </div>

        <div class="form-card">
            @RenderBody()
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}