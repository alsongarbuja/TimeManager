@page "/app/employee/create"

@rendermode InteractiveServer
@inject HttpClient Http

@using TimeManager.Frontend.Components.Shared
@using TimeManager.Frontend.Components.Wrapper

<PageTitle>Employee  - Add</PageTitle>

<FormWrapper Title="Employee "
             Subtitle="Add employee to the system"
             BackUrl="/app/employee"
             FormName="EmployeeAddForm"
             Model="@employee"
             OnSubmit="HandleSubmit"
             OnCancel="Cancel">
    <Input @bind-Value="employee.FirstName" Name="FirstName" Label="First Name" Placeholder="Enter the first name" />
    <Input @bind-Value="employee.LastName" Name="LastName" Label="Last Name" Placeholder="Enter the last name" />
    <Input @bind-Value="employee.Email" Type="email" Name="Email" Label="Email" Placeholder="Enter the email address" />
    <Input @bind-Value="employee.UniqueId" Name="UniqueId" Label="SO Id" Placeholder="Enter the SO Id" />
</FormWrapper>

@code {
    private EmployeeModel employee = new();

    private async Task<string> HandleSubmit()
    {
        try
        {
            HttpResponseMessage responseMessage = await Http.PostAsJsonAsync("api/employee", employee);

            if (responseMessage.IsSuccessStatusCode)
            {
                return "";
            }
            else
            {
                var problemDetails = await responseMessage.Content.ReadFromJsonAsync<System.Text.Json.Nodes.JsonObject>();
                return problemDetails?["detail"]?.ToString() ?? "An unexpected error occured";
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex);
            return ex.Message;
        }
    }

    private Task Cancel()
    {
        return Task.CompletedTask;
    }
}
