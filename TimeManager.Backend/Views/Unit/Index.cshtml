@using TimeManager.Backend.Models.Components
@using TimeManager.Backend.ViewModels
@model IEnumerable<UnitViewModel>

@{
    Layout = "_ListWrapper";
    ViewData["Title"] = "Unit";

    List<string> Headers = ["Name", "Department", "Description"];
    ViewData["Headers"] = Headers;
    ViewData["ModuleTitle"] = "Unit";
    ViewData["ModuleDesc"] = "Manage the unit data in the system";
    ViewData["Controller"] = "Unit";
}

@if (Model.Count() <= 0)
{
    <tr>
        <td colspan="@Headers.Count"
            class="table-empty-cell">
            No data available
        </td>
    </tr>
}
else
{
    foreach (var d in Model)
    {
        <tr class="table-row">
            <td class="table-cell">@d.Name</td>
            <td class="table-cell">@d.DepartmentName</td>
            <td class="table-cell table-desc">@d.Description</td>
            @await Html.PartialAsync("ActionTd", new ActionTdViewModel
            {
                Controller = "Unit",
                Id = d.Id,
                hasEdit = true,
                hasDelete = true,
            })
        </tr>
    }
}