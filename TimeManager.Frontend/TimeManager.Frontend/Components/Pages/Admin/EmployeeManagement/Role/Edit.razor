@page "/app/role/edit/{id:int}"

@rendermode InteractiveServer
@inject HttpClient Http

@using TimeManager.Frontend.Components.Shared
@using TimeManager.Frontend.Components.Wrapper

<PageTitle>Edit Role</PageTitle>

<FormWrapper isEdit
             Title="Role"
             Subtitle="Update the role"
             BackUrl="/app/role"
             Model="@roleModel"
             OnSubmit="HandleSubmit"
             OnCancel="Cancel">
    <Input @bind-Value="roleModel.Name" Label="Name" Name="name" Placeholder="Enter a name" />
    <Input @bind-Value="roleModel.Description" Label="Description" Name="description" Placeholder="Enter a descrption" Required="false" />
</FormWrapper>

@code {
    [Parameter]
    public int Id { get; set; }

    private bool _hasDataLoaded = false;
    private RoleModel roleModel = new();

    protected override async Task OnParametersSetAsync()
    {
        if (!_hasDataLoaded)
        {
            try
            {
                var data = await Http.GetFromJsonAsync<RoleModel>($"/api/role/{Id}");

                if (data != null)
                {
                    roleModel = data;
                    _hasDataLoaded = true;
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine(ex);
            }
        }
    }

    private async Task<string> HandleSubmit()
    {
        try
        {
            HttpResponseMessage responseMessage = await Http.PatchAsJsonAsync($"/api/role/{Id}", roleModel);

            if (responseMessage.IsSuccessStatusCode)
            {
                return "";
            }
            else
            {
                var problemDetails = await responseMessage.Content.ReadFromJsonAsync<System.Text.Json.Nodes.JsonObject>();
                return problemDetails?["detail"]?.ToString() ?? "An error occured while saving.";
            }
        }
        catch (Exception ex)
        {
            return ex.Message;
        }
    }

    private Task Cancel()
    {
        Console.WriteLine("Cancelling...");
        return Task.CompletedTask;
    }
}
