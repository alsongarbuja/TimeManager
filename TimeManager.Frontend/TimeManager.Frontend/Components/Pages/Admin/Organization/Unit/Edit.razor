@page "/app/unit/edit/{id:int}"

@rendermode InteractiveServer
@inject HttpClient Http

@using TimeManager.Frontend.Components.Shared
@using TimeManager.Frontend.Components.Wrapper

<PageTitle>Edit Unit</PageTitle>

<FormWrapper 
    isEdit
    Title="Unit"
    Subtitle="Update the unit data"
    BackUrl="/app/unit"
    Model="@unitModel"
    OnSubmit="HandleSubmit"
    OnCancel="Cancel"
>
    <Input @bind-Value="unitModel.Name" Label="Name" Name="name" Placeholder="Enter a name" />
    <Input @bind-Value="unitModel.Index"
            TValue="int"
           Type="number"
           Label="Index"
           Name="index"
           Placeholder="Enter a index" />
    <Input @bind-Value="unitModel.Description" Label="Description" Name="description" Placeholder="Enter a descrption" Required="false" />
</FormWrapper>

@code {
    [Parameter]
    public int Id { get; set; }

    private bool _hasDataLoaded = false;
    private UnitModel unitModel = new();

    protected override async Task OnParametersSetAsync()
    {
        if (!_hasDataLoaded)
        {
            try
            {
                var data = await Http.GetFromJsonAsync<UnitModel>($"/api/unit/{Id}");

                if (data != null)
                {
                    unitModel = data;
                    _hasDataLoaded = true;
                }
            } catch (Exception ex)
            {
                Console.WriteLine(ex);
            }
        }
    }

    private async Task<string> HandleSubmit()
    {
        try
        {
            HttpResponseMessage responseMessage = await Http.PatchAsJsonAsync($"/api/unit/{Id}", unitModel);

            if (responseMessage.IsSuccessStatusCode)
            {
                return "";
            } else
            {
                var problemDetails = await responseMessage.Content.ReadFromJsonAsync<System.Text.Json.Nodes.JsonObject>();
                return problemDetails?["detail"]?.ToString() ?? "An error occured while saving.";
            }
        } catch (Exception ex)
        {
            return ex.Message;
        }
    }

    private Task Cancel()
    {
        Console.WriteLine("Cancelling...");
        return Task.CompletedTask;
    }
}
