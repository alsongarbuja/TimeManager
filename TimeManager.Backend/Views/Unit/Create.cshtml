@model TimeManager.Backend.ViewModels.UnitViewModel

@{
    Layout = "_FormWrapper";
    ViewData["Title"] = "Unit - Add";
    ViewData["ModuleTitle"] = "Create Unit";
    ViewData["ModuleSubtitle"] = "Add new unit";
    ViewData["Controller"] = "Unit";
}

<form asp-controller="Unit" asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    @* TODO: ADD DEPARTMENT ID FROM AUTHORIZATION *@
    <custom-input asp-for="Name" />
    <custom-input asp-for="Description" />

    <button type="submit" class="btn btn-primary">Submit</button>
</form>