@page "/app/role"

@rendermode InteractiveServer
@inject HttpClient Http

@using TimeManager.Frontend.Components.Pages.Admin._Components
@using TimeManager.Frontend.Components.Wrapper

<PageTitle>Role</PageTitle>

<ListWrapper Title="Role"
             Subtitle="Manage the roles"
             Headers="@headers"
             isEmpty="isEmpty"
             CreateUrl="/app/role/create">
    @foreach (var r in roles)
    {
        <tr class="table-row">
            <td class="table-cell">@r.Name</td>
            <td class="table-cell table-cell-desc">@r.Description</td>
            <ActionTD 
                Url="@($"/app/role/edit/{r.Id}")"
                DeleteUrl="@($"api/role/{r.Id}")"
                OnDeleteSuccess="LoadDataAsync"
            />
        </tr>
    }
</ListWrapper>

    @code {
    private string[] headers { get; set; } = ["Name", "Description"];
    private RoleModel[] roles = [];

    private async Task LoadDataAsync()
    {
        try
        {
            roles = await Http.GetFromJsonAsync<RoleModel[]>("api/role");
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private bool isEmpty => roles.Length == 0;
}

