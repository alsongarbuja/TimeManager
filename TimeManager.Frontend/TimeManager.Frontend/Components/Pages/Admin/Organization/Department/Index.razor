@page "/app/department"

@inject HttpClient Http
@inject NavigationManager Navigation

@using TimeManager.Frontend.Components.Shared
@using TimeManager.Frontend.Components.Wrapper

<PageTitle>Department</PageTitle>

<ListWrapper 
    Title="Department"
    Headers="@departments"
    Subtitle="Manage the Departments"
    CreateUrl="/app/department/create"
    isEmpty="isEmpty"
>
    @foreach (var data in departmentModels)
    {
        var currentId = data.Id;
        <tr>
            <td class="px-6 py-4 text-left">@data.Name</td>
            <td class="px-6 py-4 text-truncate">@data.Description</td>
            <td class="px-6 py-4 flex items-center gap-2">
                <Button 
                        Type="button"
                        Classes="bg-red-500 text-white rounded-md w-fit" >
                        <i class="ri-delete-bin-7-line"></i>
                        </Button>
                <Button 
                    Type="button"
                    Classes="bg-blue-500 text-white rounded-md w-fit"
                    HandleClick="()=>NavigateToEdit(currentId)"
                    >
                    <i class="ri-edit-line"></i>
                    </Button>
            </td>
        </tr>
    }
    </ListWrapper>

@code {
    private string[] departments { get; set; } = ["Name", "Description"];
    private DepartmentModel[] departmentModels = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            departmentModels = await Http.GetFromJsonAsync<DepartmentModel[]>("api/department");
        } catch (Exception ex)
        {
            Console.WriteLine(ex);
        }
    }

    // TODO: fix this navigation
    public void NavigateToEdit(int id)
    {
        Console.WriteLine(id);
        Navigation.NavigateTo("/app/department/edit/{id}");
    }

    private bool isEmpty => departmentModels.Length == 0;
}
