@using TimeManager.Backend.Models.Components
@using TimeManager.Backend.ViewModels
@model IEnumerable<ProfileTemplateViewModel>

@{
    Layout = "_ListWrapper";
    ViewData["Title"] = "Profile Template";

    List<string> Headers = ["Role", "Employee Type", "Unit", "Shift Start Time", "Early Clock in buffer"];
    ViewData["Headers"] = Headers;
    ViewData["ModuleTitle"] = "Profile Template";
    ViewData["ModuleDesc"] = "Manage the profile templates in the department";
    ViewData["Controller"] = "ProfileTemplate";
}

@if (Model.Count() <= 0)
{
    <tr>
        <td colspan="@Headers.Count"
            class="table-empty-cell">
            No data available
        </td>
    </tr>
}
else
{
    foreach (var d in Model)
    {
        <tr class="table-row">
            <td class="table-cell">@d.Role</td>
            <td class="table-cell">@d.EmployeeType</td>
            <td class="table-cell">@d.Unit</td>
            <td class="table-cell">@d.ShiftStartTime</td>
            <td class="table-cell">@d.EarlyClockInBufferMin min</td>
            @await Html.PartialAsync("ActionTd", new ActionTdViewModel
            {
                Controller = "ProfileTemplate",
                Id = d.Id,
                hasEdit = true,
                hasDelete = true,
            })
        </tr>
    }
}