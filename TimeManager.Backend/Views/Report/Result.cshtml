@model TimeManager.Backend.ViewModels.ReportGeneratedViewModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Report Result";
}

@section styles {
    <link href="/css/report.css" rel="stylesheet" />
}

<div class="report-page">
    <div class="report-page-header">
        <div class="report-page-header-text">
            <h1 class="report-page-title">@Model.Name</h1>
            <p class="report-page-subtitle">@Model.UnitName</p>
        </div>
        <a asp-controller="Report" asp-action="Index" class="report-page-back">← Back to Reports</a>
    </div>

    @await Html.PartialAsync("ReportStat", new TimeManager.Backend.ViewModels.PartialViews.ReportStatModel
    {
        TotalHours = Model.TotalHours,
        TotalWorkedHours = Model.TotalWorkedHours,
        TotalHolidayHours = Model.TotalHolidayHours,
    })

    @await Html.PartialAsync("ReportTable", new TimeManager.Backend.ViewModels.PartialViews.ReportTablePartialViewModel
    {
        TotalHours = Model.TotalHours,
        WeekOne = new TimeManager.Backend.ViewModels.PartialViews.ReportTableWeekRow
        {
            Week = Model.WeekOne,
            Label = "Week 1"
        },
        WeekTwo = new TimeManager.Backend.ViewModels.PartialViews.ReportTableWeekRow
        {
            Week = Model.WeekTwo,
            Label = "Week 2"
        },
    })
</div>